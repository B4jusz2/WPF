<Window x:Class="Macska.MacskaAblak"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Macska adatai" Height="320" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Azonosító:" Grid.Row="0" Grid.Column="0" Margin="0,5"/>
        <TextBox x:Name="txtCatId" Grid.Row="0" Grid.Column="1" Margin="0,5"/>

        <TextBlock Text="Név:" Grid.Row="1" Grid.Column="0" Margin="0,5"/>
        <TextBox x:Name="txtName" Grid.Row="1" Grid.Column="1" Margin="0,5"/>

        <TextBlock Text="Kor:" Grid.Row="2" Grid.Column="0" Margin="0,5"/>
        <TextBox x:Name="txtAge" Grid.Row="2" Grid.Column="1" Margin="0,5"/>

        <TextBlock Text="Nem:" Grid.Row="3" Grid.Column="0" Margin="0,5"/>
        <TextBox x:Name="txtGender" Grid.Row="3" Grid.Column="1" Margin="0,5"/>

        <TextBlock Text="Fajta:" Grid.Row="4" Grid.Column="0" Margin="0,5"/>
        <ComboBox x:Name="cbBreed"
                  Grid.Row="4" Grid.Column="1" Margin="0,5"
                  DisplayMemberPath="BreedName"
                  SelectedValuePath="BreedId"/>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Mentés" Width="100" Margin="5" Click="BtnMentes_Click"/>
            <Button Content="Mégse" Width="100" Margin="5" Click="BtnMegse_Click"/>
        </StackPanel>
    </Grid>
</Window>